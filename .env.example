# ==============================================================================
# The Smooth Operator — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ==============================================================================

# --- Application -----------------------------------------------------------
# Runtime environment: development | staging | production
ENVIRONMENT=development

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# API server binding
API_HOST=0.0.0.0
API_PORT=8000

# --- Database (PostgreSQL) -------------------------------------------------
# Async connection string for SQLAlchemy
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://smoothop:smoothop@localhost:5432/smoothop

# --- Cache (Redis) ---------------------------------------------------------
# Redis connection URL for caching and task queues
REDIS_URL=redis://localhost:6379/0

# --- Vector Store (ChromaDB) -----------------------------------------------
# ChromaDB server connection for semantic search
CHROMA_HOST=localhost
CHROMA_PORT=8100

# --- LLM Providers ---------------------------------------------------------
# OpenAI API key for GPT models
OPENAI_API_KEY=sk-your-openai-api-key-here

# Google AI API key for Gemini models
GOOGLE_API_KEY=your-google-api-key-here

# Default LLM model to use for email generation
LLM_MODEL=gpt-4o-mini

# --- Embeddings & Retrieval ------------------------------------------------
# Sentence-transformer model for generating embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Cross-encoder model for reranking search results
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Observability (LangSmith) ---------------------------------------------
# LangSmith API key for LLM tracing and evaluation
LANGSMITH_API_KEY=ls-your-langsmith-api-key-here

# LangSmith project name for organizing traces
LANGSMITH_PROJECT=smooth-operator

# Enable LangSmith tracing (true | false)
LANGCHAIN_TRACING_V2=true

# --- Email (SMTP) ----------------------------------------------------------
# SMTP server for sending outreach emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here

# Sender display email
FROM_EMAIL=your-email@gmail.com

# Daily email sending limit (to avoid spam flags)
EMAIL_DAILY_LIMIT=50
